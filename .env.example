# ── Server ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# ── Database ────────────────────────────────────────────────────────
# Get from Railway: railway.app (free tier available)
DATABASE_URL=postgresql://user:password@host:5432/recipemarket

# ── Firebase (Authentication) ───────────────────────────────────────
# Get from Firebase Console → Project Settings → Service Accounts
# firebase.google.com/console
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Stripe (Payments — $2.99 one-time) ─────────────────────────────
# stripe.com/dashboard
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Test keys (dev only):
# STRIPE_SECRET_KEY=sk_test_...

# ── Cloudinary (Image uploads) ──────────────────────────────────────
# cloudinary.com — free tier: 25GB storage, 25GB bandwidth/mo
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-api-secret

# ── Kroger API (Ingredient search — FREE) ──────────────────────────
# developer.kroger.com — free, covers Kroger/Harris Teeter/Fred Meyer/Ralphs
KROGER_CLIENT_ID=your-kroger-client-id
KROGER_CLIENT_SECRET=your-kroger-client-secret

# ── Walmart API (Ingredient search) ────────────────────────────────
# developer.walmart.com
WALMART_CONSUMER_ID=your-consumer-id
WALMART_ACCESS_TOKEN=your-access-token

# ── Google APIs ─────────────────────────────────────────────────────
# console.cloud.google.com — Places API for nearby store discovery
# Also used for Google Sign-In in the app
GOOGLE_PLACES_API_KEY=AIzaSy...

# ── SerpApi (Fallback store search) ────────────────────────────────
# serpapi.com — $50/mo for 5k searches, use as backup
SERPAPI_KEY=your-serpapi-key

# ── Redis (Caching — optional but recommended) ─────────────────────
# Upstash: free tier available at upstash.com
REDIS_URL=redis://default:password@host:6379
